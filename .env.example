# Misskey Configuration
MISSKEY_URL=https://your-misskey-instance.example
MISSKEY_TOKEN=your-bot-access-token

# LLM Configuration (OpenAI-compatible API)
LLM_ENDPOINT=https://api.xiaomimimo.com/v1
LLM_API_KEY=your-api-key
LLM_MODEL=mimo-v2.5-pro

# Optional LLM Settings
MAX_TOKENS=1024
TEMPERATURE=1.0
TOP_P=0.95

# Features
ENABLE_SEARCH=false
ENABLE_THINKING=true

# Logging (error, info, debug)
LOG_LEVEL=info

# Bot Personality (use double quotes for multi-line)
SYSTEM_PROMPT="あなたは親しみやすいMisskeyボットです。
カジュアルでフレンドリーな口調で返答してください。
絵文字も適度に使ってください。
簡潔に返答してください。"
